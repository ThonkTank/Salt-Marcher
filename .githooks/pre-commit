#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# shellcheck source=.githooks/lib/sensitive-build-paths.sh
source "$SCRIPT_DIR/lib/sensitive-build-paths.sh"

blocked_paths=()
while IFS= read -r path; do
    if [[ -z "$path" ]]; then
        continue
    fi
    if sm_is_sensitive_build_path "$path"; then
        blocked_paths+=("$path")
    fi
done < <(git diff --cached --name-only)

if [[ "${#blocked_paths[@]}" -eq 0 ]]; then
    exit 0
fi

echo "Blocked commit: staged changes touch sensitive build surfaces." >&2
printf '  %s\n' "${blocked_paths[@]}" >&2
echo >&2
echo "Authoritative build checks live outside the repository in ~/Schreibtisch/SM/buildSrc." >&2
echo "The repository must only point at that external build logic through settings.gradle.kts and must not contain a buildSrc path." >&2
exit 1
