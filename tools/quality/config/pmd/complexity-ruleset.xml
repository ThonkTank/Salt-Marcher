<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="SaltMarcher Complexity Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/schema/ruleset_2_0_0.xsd">
    <description>
        Build-breaking complexity, coupling, and deterministic best-practice smell rules
        for SaltMarcher production Java sources.
    </description>

    <rule ref="category/java/design.xml/CognitiveComplexity">
        <properties>
            <property name="reportLevel" value="15" />
        </properties>
    </rule>

    <rule name="CyclomaticComplexity"
          language="java"
          since="7.0.0"
          message="The {0} ''{1}'' has a cyclomatic complexity of {2}."
          class="saltmarcher.quality.pmd.hygiene.RoleAwareCyclomaticComplexityRule"
          externalInfoUrl="https://docs.pmd-code.org/pmd-doc-7.23.0/pmd_rules_java_design.html#cyclomaticcomplexity">
        <priority>3</priority>
        <properties>
            <property name="classReportLevel" value="80" />
            <property name="methodReportLevel" value="10" />
        </properties>
    </rule>

    <rule ref="category/java/design.xml/NPathComplexity">
        <properties>
            <property name="reportLevel" value="200" />
        </properties>
    </rule>

    <rule name="CouplingBetweenObjects"
          language="java"
          since="1.04"
          message="A value of {0} may denote a high amount of coupling within the class (threshold: {1})"
          class="saltmarcher.quality.pmd.hygiene.RoleAwareCouplingBetweenObjectsRule"
          externalInfoUrl="https://docs.pmd-code.org/pmd-doc-7.23.0/pmd_rules_java_design.html#couplingbetweenobjects">
        <priority>3</priority>
        <properties>
            <property name="threshold" value="20" />
        </properties>
    </rule>

    <rule ref="category/java/design.xml/AvoidDeeplyNestedIfStmts">
        <properties>
            <property name="problemDepth" value="3" />
        </properties>
    </rule>

    <rule ref="category/java/design.xml/NcssCount">
        <properties>
            <property name="methodReportLevel" value="60" />
            <property name="classReportLevel" value="1500" />
        </properties>
    </rule>

    <rule ref="category/java/design.xml/ExcessiveParameterList">
        <properties>
            <property name="minimum" value="10" />
        </properties>
    </rule>

    <rule name="TooManyMethods"
          language="java"
          since="4.2"
          message="This class has too many methods, consider refactoring it."
          class="saltmarcher.quality.pmd.hygiene.RoleAwareTooManyMethodsRule"
          externalInfoUrl="https://docs.pmd-code.org/pmd-doc-7.23.0/pmd_rules_java_design.html#toomanymethods">
        <priority>3</priority>
    </rule>

    <rule ref="category/java/design.xml/TooManyFields" />

    <rule ref="category/java/design.xml/ExcessivePublicCount" />

    <rule name="ExcessiveImports"
          language="java"
          since="1.04"
          message="A high number of imports ({0}) can indicate a high degree of coupling within an object; current threshold is {1}."
          class="saltmarcher.quality.pmd.hygiene.RoleAwareExcessiveImportsRule"
          externalInfoUrl="https://docs.pmd-code.org/pmd-doc-7.23.0/pmd_rules_java_design.html#excessiveimports">
        <priority>3</priority>
    </rule>

    <rule name="GodClass"
          language="java"
          since="5.0"
          message="Possible God Class (WMC={0}, ATFD={1}, TCC={2}%)"
          class="saltmarcher.quality.pmd.hygiene.RoleAwareGodClassRule"
          externalInfoUrl="https://docs.pmd-code.org/pmd-doc-7.23.0/pmd_rules_java_design.html#godclass">
        <priority>3</priority>
    </rule>

    <rule name="DataClass"
          language="java"
          since="6.0.0"
          message="The class ''{0}'' is suspected to be a Data Class (WOC={1}, NOPA={2}, NOAM={3}, WMC={4})"
          class="saltmarcher.quality.pmd.hygiene.RoleAwareDataClassRule"
          externalInfoUrl="https://docs.pmd-code.org/pmd-doc-7.23.0/pmd_rules_java_design.html#dataclass">
        <priority>3</priority>
    </rule>

    <rule ref="category/java/design.xml/AbstractClassWithoutAnyMethod" />

