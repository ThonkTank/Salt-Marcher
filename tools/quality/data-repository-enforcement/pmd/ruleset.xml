<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="SaltMarcher Data Repository Enforcement Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/schema/ruleset_2_0_0.xsd">
    <description>
        Data Repository source-level architecture rules for SaltMarcher production Java sources.
    </description>

    <rule name="DataRepositorySourceMechanicsRule"
          language="java"
          message="Data repository source-mechanics violation"
          class="saltmarcher.quality.pmd.data.DataRepositorySourceMechanicsRule">
        <priority>1</priority>
    </rule>
</ruleset>
