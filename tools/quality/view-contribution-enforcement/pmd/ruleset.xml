<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="SaltMarcher ViewContribution Enforcement Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/schema/ruleset_2_0_0.xsd">
    <description>
        Contribution-owned source-level PMD architecture rules for SaltMarcher production Java sources.
    </description>

    <rule name="ViewContributionEntrypointRule"
          language="java"
          message="SaltMarcher view contribution entrypoint violation"
          class="saltmarcher.quality.pmd.view.contribution.ViewContributionEntrypointRule">
        <priority>1</priority>
    </rule>
</ruleset>
