<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="SaltMarcher Data Query Enforcement Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/schema/ruleset_2_0_0.xsd">
    <description>
        Data Query source-level architecture rules for SaltMarcher production Java sources.
    </description>

    <rule name="DataQueryNoSourceMechanicsRule"
          language="java"
          message="Data Query source policy violation"
          class="saltmarcher.quality.pmd.data.DataQueryNoSourceMechanicsRule">
        <priority>1</priority>
    </rule>

    <rule name="DataQueryReadOnlySourceShapeRule"
          language="java"
          message="Data Query read-only source-shape violation"
          class="saltmarcher.quality.pmd.data.DataQueryReadOnlySourceShapeRule">
        <priority>1</priority>
    </rule>

</ruleset>
