<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="SaltMarcher Domain Service Enforcement Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/schema/ruleset_2_0_0.xsd">
    <description>
        Domain service source-level architecture rules for SaltMarcher production Java sources.
    </description>

    <rule name="DomainServiceNoCeremonialIndirectionRule"
          language="java"
          message="Domain service ceremonial indirection violation"
          class="saltmarcher.quality.pmd.indirection.CeremonialIndirectionRule">
        <priority>1</priority>
        <properties>
            <property name="ruleKind" value="domainService"/>
        </properties>
    </rule>
</ruleset>
